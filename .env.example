# Structured logging (stdout JSON). debug | info | warn | error
LOG_LEVEL=info

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
GRAILED_APP_ID=
GRAILED_API_KEY=
ANTHROPIC_API_KEY=
SCRAPFLY_API_KEY=
GRAFANA_ADMIN_PASSWORD=fashion

# --- Web app (dashboard) auth ---
# First-boot owner account. Set both to bootstrap the first admin; the app
# refuses to start internet-exposed with no admin. Safe to leave set — it is
# idempotent (re-applies the password on each boot).
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Stable cookie signing secret (>=16 chars). Generate: openssl rand -hex 32
# If unset, an ephemeral secret is used and sessions drop on restart.
SESSION_SECRET=
# Encryption key for secrets at rest (64 hex chars). Generate: openssl rand -hex 32
# Required to enable the Secrets/integrations editor.
SECRETS_KEY=
# Set true when served over HTTPS (behind a TLS-terminating reverse proxy).
COOKIE_SECURE=false
# Public domain for the Caddy reverse proxy (auto-HTTPS). Use "localhost" for
# local self-signed TLS. Example: monitor.example.com
WEB_DOMAIN=localhost
