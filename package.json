{
  "name": "fashion-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Personal resale monitoring with LLM aesthetic scoring",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev:run": "pnpm --filter @fm/cli exec tsx src/run.ts",
    "dev:report": "pnpm --filter @fm/cli exec tsx src/report.ts",
    "dev:dashboard": "pnpm --filter @fm/cli exec tsx src/dashboard.ts",
    "dev:web": "pnpm --filter @fm/web dev",
    "start:run": "node apps/cli/dist/run.js",
    "start:report": "node apps/cli/dist/report.js",
    "start:dashboard": "node apps/cli/dist/dashboard.js",
    "lint": "turbo run lint",
    "format": "prettier --write \"packages/**/*.ts\" \"apps/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "pnpm --filter @fm/core test:coverage",
    "test:live": "pnpm --filter @fm/core test:live",
    "verify:scrapers": "pnpm --filter @fm/core exec tsx ../../scripts/verify-scrapers.ts",
    "test:e2e": "playwright test",
    "test:mutation": "pnpm --filter @fm/core exec stryker run --configFile stryker.conf.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.4",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
